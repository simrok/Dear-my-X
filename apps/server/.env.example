# =====================================================
# apps/server/.env.example
# =====================================================
# 사용법:  cp apps/server/.env.example apps/server/.env

# --- 앱 ---
APP_ENV=development           # development | staging | production
APP_NAME=dear-my-x-server
APP_DEBUG=true
APP_LOG_LEVEL=INFO

# --- API ---
API_V1_PREFIX=/api/v1
CORS_ALLOW_ORIGINS=http://localhost:8081,http://localhost:19006,exp://

# --- DB (로컬 개발: docker-compose 의 db 컨테이너 또는 호스트 Postgres) ---
# 로컬 호스트에서 직접 실행:
DATABASE_URL=postgresql+asyncpg://dear_my_x:dear_my_x_pw@localhost:5432/dear_my_x
# docker-compose 의 server 컨테이너에서는 host=db 로 자동 오버라이드 됨

# --- Supabase ---
# 프로젝트 설정 → API 에서 복사
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_STORAGE_BUCKET=dear-my-x-uploads

# --- AI ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- 보안 ---
# JWT 검증은 Supabase 가 발급한 토큰을 사용하므로 SUPABASE_JWT_SECRET 으로 대체 가능
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
