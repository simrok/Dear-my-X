# =====================================================
# Dear my X — 루트 .env.example
# =====================================================
# 이 파일은 docker-compose 와 같이 "여러 서비스가 공유"하는 변수를 위한 예시입니다.
# 각 앱은 자체 .env 파일을 우선 사용합니다 (apps/server/.env, apps/mobile/.env).
# 로컬 개발 시:  cp .env.example .env
# =====================================================

# --- PostgreSQL (docker-compose 의 db 서비스) ---
POSTGRES_USER=dear_my_x
POSTGRES_PASSWORD=dear_my_x_pw
POSTGRES_DB=dear_my_x
POSTGRES_PORT=5432

# --- Server 컨테이너 노출 포트 ---
SERVER_PORT=8000

# 모바일이 로컬 서버를 가리킬 때 사용할 베이스 URL (Expo 가 읽음)
# iOS 시뮬레이터: http://localhost:8000
# Android 에뮬레이터: http://10.0.2.2:8000
# 실기기: 호스트 PC 의 LAN IP (예: http://192.168.0.10:8000)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
